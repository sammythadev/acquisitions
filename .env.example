# Server Configuration
PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Database Configuration
# For development with Neon Local (Docker):
# DATABASE_URL=postgres://neon:npg@neon-local:5432/neondb?sslmode=require
# For production with Neon Cloud:
# DATABASE_URL=postgresql://username:password@endpoint.neon.tech/database?sslmode=require
DATABASE_URL=your_database_url_here

# Neon Local Configuration (for development)
# Get these from your Neon Console: https://console.neon.tech
NEON_API_KEY=your_neon_api_key
NEON_PROJECT_ID=your_neon_project_id
PARENT_BRANCH_ID=main

# Authentication
JWT_SECRET=your_jwt_secret_here

# External Services
ARCHET_KEY=your_arcjet_key_here